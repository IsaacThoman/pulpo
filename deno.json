{
  "imports": {
    "hono": "jsr:@hono/hono@^4.11.3",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@prisma/client": "npm:@prisma/client@6.19.2",
    "openai": "npm:openai@^6.29.0",
    "js-tiktoken": "npm:js-tiktoken@^1.0.21",
    "zod": "npm:zod@^4.3.4"
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-env --allow-ffi --env-file=.env main.ts",
    "dev": "deno run --allow-net --allow-read --allow-env --allow-ffi --env-file=.env --watch main.ts",
    "startnoenv": "deno run --allow-net --allow-read --allow-env --allow-ffi main.ts"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "fmt": {
    "exclude": [
      "frontend/src/**/*.html"
    ]
  }
}
